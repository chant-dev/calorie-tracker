generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Entry {
  id         String   @id @default(cuid())
  date       String
  foodName   String?
  calories   Float
  protein    Float
  sourceType String   @default("manual")
  quantity   Float?
  unit       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
}

model SavedFood {
  id         String   @id @default(cuid())
  name       String
  calories   Float
  protein    Float
  quantity   Float?
  unit       String?
  sourceType String   @default("manual")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
